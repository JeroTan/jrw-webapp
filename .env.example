# Identity & Auth
SEED_ADMIN_EMAIL="example@mail.com"
SEED_ADMIN_PASSWORD="password"
JWT_SECRET="your-jwt-secret-here"

# Database - Supabase (Standard PostgreSQL)
# Connect to Supabase via connection pooling (Used by the Application)
SUPABASE_DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection to the database (Used for Migrations)
SUPABASE_DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# Third-Party Services
RESEND_API_KEY="re_..."
PAYMONGO_SECRET_KEY="sk_test_..."
