generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Identity Domain ---

model Admin {
  id            String     @id @default(cuid())
  email         String     @unique
  password_hash String
  is_owner      Boolean    @default(false)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  audit_logs    AuditLog[]

  @@map("admins")
}

model Customer {
  id             String   @id @default(cuid())
  email          String   @unique
  first_name     String?
  last_name      String?
  phone          String?
  street_address String?
  barangay       String?
  city_province  String?
  postal_code    String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  orders         Order[]
  reviews        Review[]

  @@map("customers")
}

// --- Catalog Domain ---

model Product {
  id          String            @id @default(cuid())
  name        String
  brand       String?
  tags        String[]
  description String            @db.Text
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  photos      ProductPhoto[]
  variants    ProductVariant[]
  categories  ProductCategory[]
  snapshots   OrderSnapshot[]
  reviews     Review[]

  @@map("products")
}

model ProductPhoto {
  id         String           @id @default(cuid())
  name       String?
  image_link String
  product_id String
  product    Product          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variants   ProductVariant[] @relation("VariantPhotos")

  @@map("product_photos")
}

model Category {
  id       String            @id @default(cuid())
  name     String
  type     CategoryType
  products ProductCategory[]

  @@map("categories")
}

enum CategoryType {
  CLOTHING
  STYLE
  SEASON
}

model ProductCategory {
  product_id  String
  category_id String
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([product_id, category_id])
  @@map("product_categories")
}

model ProductVariant {
  id                 String         @id @default(cuid())
  name               String
  stock              Int            @default(0)
  price              Decimal        @db.Decimal(10, 2)
  sku                String         @unique
  is_preorder        Boolean        @default(false)
  expected_release   DateTime?
  stock_lock_version Int            @default(0)
  product_id         String
  product            Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  photos             ProductPhoto[] @relation("VariantPhotos")

  @@map("product_variants")
}

// --- Transaction Domain ---

model Order {
  id            String          @id @default(cuid())
  customer_id   String?
  customer      Customer?       @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  status        OrderStatus     @default(UNPAID)
  shipping_type ShippingType    @default(STANDARD)
  total_amount  Decimal         @db.Decimal(10, 2)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  snapshots     OrderSnapshot[]
  reviews       Review[]

  @@map("orders")
}

enum OrderStatus {
  UNPAID
  PRE_ORDERED
  PAID
  CANCELLED
  ON_THE_WAY
  FULFILLED
  FAILED
}

enum ShippingType {
  STANDARD
  NEXT_DAY
}

model OrderSnapshot {
  id                String   @id @default(cuid())
  order_id          String
  order             Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product_id        String?
  product           Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  product_name      String
  variant_name      String
  price_at_purchase Decimal  @db.Decimal(10, 2)
  quantity          Int      @default(1)

  @@map("order_snapshots")
}

model Review {
  id          String   @id @default(cuid())
  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  product_id  String
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  order_id    String
  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  rating      Int
  comment     String?  @db.Text
  created_at  DateTime @default(now())

  @@map("reviews")
}

// --- Audit Domain ---

model AuditLog {
  id         String   @id @default(cuid())
  admin_id   String
  admin      Admin    @relation(fields: [admin_id], references: [id])
  action     String
  entity     String
  entity_id  String?
  details    Json?
  created_at DateTime @default(now())

  @@map("audit_logs")
}
